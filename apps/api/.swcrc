{
  "$schema": "http://json.schemastore.org/swcrc",
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "decorators": true
    },
    "target": "es2023",
    "keepClassNames": true,
    "experimental": {
      "keepImportAttributes": true
    }
  },
  "module": {
    "type": "es6"
  },
  "sourceMaps": true
}
