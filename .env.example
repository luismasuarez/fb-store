# === DATABASE ===
# When using docker-compose, use:
# DATABASE_URL="postgresql://fbstore:fbstore@postgres:5432/fbstore"
# When running locally, use:
DATABASE_URL="postgresql://fbstore:fbstore@localhost:5432/fbstore"

# === API KEY ===
# Used to authenticate dashboard requests to the scraper API
SCRAPER_API_KEY="change-me-to-a-random-key"

# === OPTIONAL ===
# Server port (default: 3001)
# PORT=3001

# Custom Chrome/Chromium binary path (default: auto-detect)
# CHROME_PATH="/usr/bin/chromium"

# Profiles directory (default: ./profiles)
# PROFILE_DIR="./profiles"

# Scroll delay in ms between scrolls during scraping (default: 4000)
# SCROLL_DELAY_MS=4000

# === AI PROCESSOR ===
# Configured via dashboard at /settings, but these env vars work as defaults:
# AI_PROVIDER="openrouter"
# OPENROUTER_API_KEY="sk-or-..."
# AI_MODEL="openai/gpt-4o-mini"
