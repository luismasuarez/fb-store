# === DATABASE ===
DATABASE_URL="postgresql://fbstore:fbstore@localhost:5432/fbstore"

# === REDIS ===
REDIS_URL="redis://localhost:6379"

# === AI PROVIDER ===
# "openai" | "anthropic" | "openrouter"
AI_PROVIDER="openrouter"
AI_MODEL="openai/gpt-4o-mini"
AI_API_KEY="sk-..."
OPENROUTER_API_KEY=""

# === FACEBOOK ACCOUNTS ===
FB_ACCOUNTS='[{"email":"user@example.com","profile":"/app/profiles/cuenta-1"}]'
ACTIVE_ACCOUNT_INDEX=0

# === FACEBOOK GROUPS ===
FB_GROUPS='[{"id":"123456789","name":"Grupo Ejemplo","max_posts":30}]'

# === SCRAPE SCHEDULE ===
SCRAPE_INTERVAL_MINUTES=240
SCRAPE_HOURS_START=8
SCRAPE_HOURS_END=22

# === APP ===
APP_NAME="FB Store"
