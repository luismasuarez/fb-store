{
  "name": "fb-store",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @fb-store/scraper dev",
    "build": "pnpm --filter @fb-store/scraper build",
    "start": "pnpm --filter @fb-store/scraper start",
    "test": "pnpm --filter @fb-store/scraper test",
    "db:generate": "cd packages/scraper && npx prisma generate",
    "db:push": "cd packages/scraper && DATABASE_URL=postgresql://fbstore:fbstore@localhost:5432/fbstore npx prisma db push"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.13.0"
  }
}
